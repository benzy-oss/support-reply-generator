# Copy this file to ".env.local" and fill in real values.
# .env.local is git-ignored, so secrets are never committed.
# These are read on the SERVER only (no NEXT_PUBLIC_ prefix), so the API key
# is never sent to the browser.

# Your Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Internal manager address that escalation emails are sent to.
# For testing without verifying a domain, you can use:
#   delivered@resend.dev   <- Resend's test inbox (safe, no real person)
#   or the email you signed up to Resend with
MANAGER_EMAIL=manager@yourcompany.com

# Optional. The "from" address shown on the email.
# Defaults to onboarding@resend.dev (works for testing).
# To send to ANY real address, verify a domain in Resend and use an address on it.
RESEND_FROM_EMAIL=Support Escalations <onboarding@resend.dev>
